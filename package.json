{
  "name": "backend",
  "version": "1.0.0",
  "description": "Hospital department-wise audit checklist backend (Node.js + Express + MongoDB)",
  "main": "src/server.js",
  "scripts": {
    "start": "cd backend && node src/server.js",
    "build": "npm --prefix frontend install && npm --prefix frontend run build",
    "dev": "cd backend && nodemon src/server.js",
    "seed": "node src/seed/seed.js",
    "seed:cs": "node src/seed/seedCSForm.js",
    "seed:dummy": "node src/scripts/seedDummyData.js",
    "seed:complete": "node src/scripts/seedCompleteDummyData.js",
    "seed:multidept-dummy": "node src/scripts/seedMultiDeptDummyData.js",
    "seed:perfect": "node src/scripts/seedPerfectData.js",
    "clear-db": "node src/scripts/clearDatabase.js",
    "clear-data": "node src/scripts/clearDataKeepUsersDepts.js",
    "clear-departments": "node src/scripts/clearDepartments.js",
    "clear-patients": "node src/scripts/clearPatientData.js",
    "clear-submissions-seed": "node src/scripts/clearSubmissionsAndSeed.js",
    "create-checklists": "node src/scripts/createAllDepartmentChecklists.js",
    "seed:nabh": "node src/scripts/seedNABHQualityStandards.js",
    "seed:dummy-forms": "node src/scripts/seedDummyFormsChecklists.js",
    "seed:missing": "node src/scripts/seedMissingSubmissions.js",
    "seed:comprehensive": "node src/scripts/seedComprehensiveData.js",
