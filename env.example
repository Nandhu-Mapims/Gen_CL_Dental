# Copy to .env and set values. Used by docker-compose and docker-compose.prod.yml.
# Do NOT commit .env. On Hostinger, set vars in Container Environment UI.

# Required for backend
JWT_SECRET=

# MongoDB - use service name "mongo" when running in Docker (no host port exposed).
# Local dev: MONGO_URI=mongodb://localhost:27017/gen_cl_dental
# Docker:    MONGO_URI=mongodb://mongo:27017/gen_cl_dental
MONGO_URI=mongodb://mongo:27017/gen_cl_dental

# Public URL for CORS (no trailing slash). Domain deployment:
CORS_ORIGIN=https://gencl.mapims.edu.in

# Optional: host port for frontend (default 8088 to avoid 80, 3000, 5000, 8085, 5010, 27017)
# HTTP_PORT=8088
